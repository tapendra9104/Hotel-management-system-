# =========================
# SERVER CONFIGURATION
# =========================
PORT=5001
NODE_ENV=development
LOG_LEVEL=info
API_VERSION=3.0.0
APP_NAME=GrandStay Hotel API

# =========================
# DATABASE CONFIGURATION
# =========================
SQLITE_DATABASE_PATH=backend/storage/grandstay.sqlite

# =========================
# AUTHENTICATION
# =========================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# =========================
# CORS CONFIGURATION
# =========================
CORS_ORIGIN=http://localhost:5001
FRONTEND_URL=http://localhost:5001

# =========================
# OPTIONAL ADMIN SEED
# =========================
ADMIN_NAME=GrandStay Admin
ADMIN_EMAIL=admin@grandstayhotel.com
ADMIN_PASSWORD=Admin@12345
